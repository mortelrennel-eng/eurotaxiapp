# Example keystore.properties
# Do NOT commit your real keystore or passwords.
# Recommended: store actual keystore and passwords in CI secrets or ~/.gradle/gradle.properties

# Path to the keystore file. Can be absolute or relative to the Android project directory.
storeFile=/absolute/path/to/my-release-key.jks
storePassword=yourStorePassword
keyAlias=my-key-alias
keyPassword=yourKeyPassword
